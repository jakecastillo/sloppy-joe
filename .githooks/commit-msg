#!/bin/sh
# Enforce Conventional Commits on the subject line.
# Docs: docs/conventional-commits.md  ·  installed via `make hooks`.
subject=$(head -n1 "$1")

# Let merges, reverts, and autosquash commits through untouched.
case "$subject" in
"Merge "* | "Revert "* | "fixup! "* | "squash! "*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'
if printf '%s' "$subject" | grep -Eq "$pattern"; then
	exit 0
fi

echo "✗ commit message is not a Conventional Commit:" >&2
echo "    $subject" >&2
echo "  expected: <type>(<scope>)?: <description>   e.g. feat(engine): enforce budget" >&2
echo "  types: feat fix docs style refactor perf test build ci chore revert" >&2
echo "  see docs/conventional-commits.md" >&2
exit 1
